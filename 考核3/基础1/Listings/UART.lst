   8          
   9          void UART_Init(void)    //9600bps@11.0592MHz
  10          {
  11   1              PCON |= 0x80;           //使能波特率倍速位SMOD
  12   1              SCON = 0x50;            //8位数据,可变波特率
  13   1      //      AUXR &= 0xBF;           //定时器时钟12T模式
  14   1      //      AUXR &= 0xFE;           //串口1选择定时器1为波特率发生器
  15   1              TMOD &= 0x0F;           //设置定时器模式
  16   1              TMOD |= 0x20;           //设置定时器模式
  17   1              TL1 = 0xFA;                     //设置定时初始值
  18   1              TH1 = 0xFA;                     //设置定时重载值
  19   1              ET1 = 0;                        //禁止定时器中断
  20   1              TR1 = 1;                        //定时器1开始计时
  21   1              EA=1;
  22   1              ES=1;
  23   1      }
  24          
  25          /**
  26            * @brief  串口发送一个字节数据
  27            * @param      Byte要发送的一个字节数据
  28            * @retval     无
  29            */
  30          
  31          char putchar(char ch)
  32          {
  33   1          SBUF = ch;   // 把字符写入串口发送寄存器（硬件核心）
  34   1          while(TI == 0); // 等待发送完成
  35   1          TI = 0;       // 清发送标志
  36   1          return ch;
  37   1      }
  38          
  39          void UART_SendByte(unsigned char Byte)
  40          {
  41   1              SBUF=Byte;
  42   1              while(TI==0);
  43   1              TI=0;
  44   1      }
